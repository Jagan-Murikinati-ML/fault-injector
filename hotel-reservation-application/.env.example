# Global Tracing Configuration
# Set to 'true' to enable tracing for all services
# Set to 'false' to disable tracing for all services
GLOBAL_TRACING_ENABLED=true

# OpenTelemetry Collector Endpoint
OTEL_COLLECTOR_ENDPOINT=http://otel-collector:4318

# Service Namespace
SERVICE_NAMESPACE=hotel-reservation
SERVICE_VERSION=1.0.0

